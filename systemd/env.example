# Environment file for the Authentik Podman Quadlet stack.
#
# Copy this file to .env and fill in the required values before starting
# any services:
#
#   cp ~/.config/containers/systemd/.env.example ~/.config/containers/systemd/.env
#   $EDITOR ~/.config/containers/systemd/.env
#
# WARNING: The EnvironmentFile= directive in each container unit does NOT use
# the '-' prefix, so a missing .env file will cause a hard activation failure.
# Ensure .env exists and contains all required keys before running
# `systemctl --user daemon-reload` and starting the stack.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# Name of the PostgreSQL database created on first start.
# Default: authentik
PG_DB=authentik

# PostgreSQL username used by Authentik to connect to the database.
# Default: authentik
PG_USER=authentik

# PostgreSQL password for PG_USER.
# Required — no default. Choose a strong random value.
# Example: openssl rand -base64 36 | tr -d '\n'
PG_PASS=changeme

# ---------------------------------------------------------------------------
# Authentik
# ---------------------------------------------------------------------------

# Secret key used by Authentik for cryptographic signing (sessions, tokens).
# Required — no default. Must be a long, random string and kept secret.
# Example: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=changeme
